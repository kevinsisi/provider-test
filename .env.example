# opencode server - environment variables
#
# Out of the box: opencode/deepseek-v4-flash-free is used (free, no key required).
#
# To unlock paid zen models:
OPENCODE_API_KEY=
#
# To add OpenAI provider (API key or use OAuth via port 1455):
OPENAI_API_KEY=
#
# To add Gemini provider:
GEMINI_API_KEY=
#
# To password-protect the server (leave empty for no auth):
OPENCODE_SERVER_PASSWORD=
